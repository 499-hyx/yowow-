# Cron LLM email job. Copy to a server-side secret store or a local file outside git.

# anthropic | openai
LLM_PROVIDER=anthropic

# Anthropic mode
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI-compatible mode
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Required for openai mode; optional for anthropic mode.
MODEL_NAME=
LLM_MAX_TOKENS=2500
LLM_TIMEOUT_SECONDS=120

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=1
SMTP_USE_SSL=0
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
EMAIL_SUBJECT_PREFIX=[YOWOW]
