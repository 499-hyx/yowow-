{
  "name": "yowow-adaptation",
  "version": "0.1.0",
  "private": true,
  "description": "多赛道 × 多平台 × 多定位 内容桥梁系统 · 独立站（与 yowow-content-board 彻底分开）",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "node scripts/dev-with-track-prompts.mjs",
    "build": "node scripts/ensure-track-prompts.mjs && node scripts/next-with-env.mjs build",
    "start": "node scripts/next-with-env.mjs start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "ensure:track-prompts": "node scripts/ensure-track-prompts.mjs",
    "validate:configs": "node scripts/validate-configs.mjs",
    "test": "node --test --test-concurrency=1 test/*.test.mjs",
    "test:e2e": "playwright test",
    "test:golden": "node --test test/p0-maintainable.test.mjs test/golden-adaptation.test.mjs"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
